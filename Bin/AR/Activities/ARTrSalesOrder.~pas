procedure TfmARTrSalesOrder.CeKStatus;
Begin
  with quAct, SQL do
  begin
    Close; Clear;
    Add(' SELECT TOP 1 KonInvPelID FROM ARTrKonInvPelHd  '
       +' WHERE SOID='''+quMainPOID.AsString+'''');
    Open;
    if not IsEmpty then
    begin
      MsgInfo('Sudah ada Invoice ['+quAct.FieldByName('KonInvPelID').AsString+'], tidak bisa edit/Delete lagi');
      Abort;
    end;
  end;
End;

procedure TfmARTrSalesOrder.CekStatusDetil;
Begin
  with quAct, SQL do
     begin
        Close; Clear;
        Add('SELECT TOP 1 KonInvPelID FROM ARTrKonInvPelDt '
           +' WHERE KonTransBrgID='''+quMainPOID.AsString+''' AND ItemID='''+quDetilItemID.AsString+''' ');
        Open;
        if not IsEmpty then
        begin
           MsgInfo('Sudah ada Invoice ['+quAct.FieldByName('KonInvPelID').AsString+'], tidak bisa edit/Delete lagi');
           Abort;
        end;
     end;
End;

procedure TfmARTrSalesOrder.CeKretur;
Begin
  with quAct, SQL do
     begin
        Close; Clear;
        Add(' SELECT top 1 KonReturID FROM ARTrKonReturDt  '
           +' WHERE KonTransBrgID='''+quMainPOID.Value+'''');
        Open;
        if not IsEmpty then
