      'round(A.Discount,0)  , A.Administrasi  ,'
      
        'round(Case When A.FgTax= '#39'Y'#39' then ROUND((sum(qty*(Price+Komisi))' +
        '-A.Discount)*10/100,0) else 0 end,0) as Pajak,'
      
        'round(SUM (Qty*(Price+Komisi)) +(isnull(A.Charge,0)/100)*(SUM (Q' +
        'ty*(Price+Komisi)))-A.Discount+A.Administrasi+(Case When A.FgTax' +
        '= '#39'Y'#39' then (sum(qty*(Price+Komisi))-A.Discount)*10/100 else 0 en' +
        'd),0) as GT ,'
      
