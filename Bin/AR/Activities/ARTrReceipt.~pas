{$R *.dfm}


procedure TfmARtrReceipt.TTLRI;
Begin
  qutotal.Requery();

  With quAct,sql do
  Begin
    Close;Clear;
    add(' Update ArtrReceiptHD SET TTLRI='''+Formatcurr('0.00',quTotalTotal.AsCurrency)+''' '
       +' WHERE RIID='''+quMainRIID.AsString+'''');
    ExecSQL;
  End;
End;

procedure TfmARTrReceipt.quMainBeforePost(DataSet: TDataSet);
var ST : string;
begin
  inherited;
  if Trim(quMainTransDate.AsString)='' then
  begin
    MsgInfo('Tanggal transaksi tidak boleh kosong');
    quMainTransDate.FocusControl;
    Abort;
  End;

  if Trim(quMainCustID.AsString)='' then
  begin
    MsgInfo('Kode Customer tidak boleh kosong');
    quMainCustID.FocusControl;
    Abort;
  End;

  if qumain.State = dsinsert then
  begin
    ST := 'RI-'+PT+ FormatDateTime('/YY/MM/', quMainTransDate.AsDateTime);
    quMainRIID.Value  := ST + FormatFloat('0000', RunNumberGL(quAct, 'ARTrReceiptHD', 'RIID', ST, '0') + 1);
  end;

  quMainUpdDate.AsDateTime := GetServerDateTime;
  quMainUpdUser.AsString := dmMain.UserId;
end;

procedure TfmARTrReceipt.dsMainStateChange(Sender: TObject);
begin
  inherited;
  SetBtnOperationVisible(bbSave,bbCancel,FActDS);
  SetReadOnly(txtKonInvPelID,TRUE);
end;

procedure TfmARTrReceipt.FormShow(Sender: TObject);
begin
  FFieldOrder := 'CONVERT(VARCHAR(8),TransDate,112), RIID';
  FFieldTgl   := 'TransDate';
  SettingDxGrid(dxDBGrid1);
  inherited;
  quMain.Active     := TRUE;
  quDetil.Active    := TRUE;
  quTotal.Active    := TRUE;
end;

procedure TfmARTrReceipt.quMainNewRecord(DataSet: TDataSet);
begin
  inherited;
  quMainTransdate.AsDateTime := Date;
  quMainTTLRI.AsCurrency := 0;
  quMainFlag.AsString := Flag;
end;

procedure TfmARTrReceipt.txtPelangganIDButtonClick(Sender: TObject;
  AbsoluteIndex: Integer);
begin
  inherited;
  with TfmSearch.Create(Self) do
  try
     Title := 'Pelanggan';
     SQLString := 'SELECT CustName as Nama_Pelanggan,City as Kota,CustId as Kode_Pelanggan '
                 +' FROM ARMsCustomer ORDER BY CustName ';
     if ShowModal = MrOK then
     begin
       if quMain.State = dsBrowse then quMain.Edit;
       quMainCustId.Value := Res[2];
     end;
  finally
     Free;
  end;
end;

procedure TfmARTrReceipt.dxDBGrid1ItemNameButtonClick(Sender: TObject;
  AbsoluteIndex: Integer);
begin
  inherited;
  with TfmSearch.Create(Self) do
  try
     Title := 'Invoice';
     SQLString :=  'select CONVERT(varchar(10),A.Transdate,103) as Tgl,A.KonInvPelID,A.TTLKJ as Total,A.SOID,C.POCust from artrkoninvpelhd A '
                  +'inner join Artrpurchaseorderhd C on A.SOID=C.POID '
                  +'Where A.CustId='''+quMainCustID.AsString+''' And A.KonInvPelID Not In (select B.koninvpelid from Artrreceiptdt B) ';
     if ShowModal = MrOK then
     begin
       if quDetil.State = dsBrowse then quDetil.Edit;
       quDetilKonInvPelID.Value := Res[1];
       quDetilAmount.Value := strtocurr(Res[2]);
       quDetilNoPO.Value := Res[3];
       quDetilNoDO.Value := Res[4];
     end;
  finally
     Free;
  end;
end;

procedure TfmARTrReceipt.quMainCalcFields(DataSet: TDataSet);
begin
  inherited;
  with quAct,SQL do
  begin
    Close;Clear;
    Add('Select CustName From ArMsCustomer Where CustId='''+qumaincustId.AsString+''' ');
    Open;
  end;
  quMainCustName.AsString := quAct.FieldByName('CustName').AsString;
end;

procedure TfmARTrReceipt.dsDetilStateChange(Sender: TObject);
begin
  inherited;
  SetReadOnly(dxDBGrid1Value,TRUE);
  SetReadOnly(dxDBGrid1ItemName,qudetil.State<>dsInsert);
end;

procedure TfmARTrReceipt.BtlBrgClick(Sender: TObject);
begin
  inherited;
  quDetil.Cancel;
end;

procedure TfmARTrReceipt.bbSimpanDetilClick(Sender: TObject);
begin
  inherited;
  if Self.quDetil.State = dsInsert then
  begin
   Self.quDetil.Edit;
   Self.quDetil.Post;
   Self.quDetil.Requery();
  end;
  if Self.quDetil.State = dsEdit then
  begin
   quDetil.Post;
  end;
end;

procedure TfmARTrReceipt.KrgBrgClick(Sender: TObject);
begin
  inherited;
  if quDetil.IsEmpty then Abort;
  if (dsdetil <> nil) and (dsDetil.DataSet <> nil) and
     (MessageDlg('Hapus Nota ?', mtConfirmation, [mbYes, mbNo], 0) = mrYes) then
        dsDetil.DataSet.Delete;
end;

procedure TfmARTrReceipt.TmbBrgClick(Sender: TObject);
begin
  inherited;
  quDetil.Append;
end;

procedure TfmARTrReceipt.quDetilAfterPost(DataSet: TDataSet);
