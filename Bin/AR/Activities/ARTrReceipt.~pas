end;

procedure TfmARTrReceipt.quDetilBeforeDelete(DataSet: TDataSet);
begin
  inherited;
  TTLRI;
end;

procedure TfmARTrReceipt.quDetilAfterDelete(DataSet: TDataSet);
begin
  inherited;
  TTLRI;
end;

procedure TfmARTrReceipt.quDetilBeforePost(DataSet: TDataSet);
begin
  inherited;

  with quAct, SQL do
  begin
    Close; Clear;
    Add(' SELECT Top 1 KoninvPelid FROM ARTrKonInvPelHD WHERE KonInvPelID='''+quDetilKonInvPelID.Value+''' ');
    Open;
  end;

  if quAct.RecordCount < 1 then
  begin
     MsgInfo('Data Invoice Tidak Ditemukan');
     quDetilKonInvPelID.FocusControl;
     Abort;
  end;

  quDetilUpdDate.AsDateTime := GetServerDateTime;
  quDetilUpdUser.AsString := dmmain.UserId;
end;

procedure TfmARTrReceipt.dxButton1Click(Sender: TObject);
begin
  inherited;
  TTLRI;

  with TfmARQRRptReceipt.Create(Self) do
  try
    qlbTerbilang.Caption :=  'Terbilang:'+char(13)+ convert(FormatFloat(sEditFormat, quTotalTotal.AsCurrency))+'Rupiah #';
    laGT.Caption := quTotalTotal.AsString; qrlPeriode.Caption := 'Serpong, '+FormatDateTime('d MMMM yyyy',quMainTransdate.AsDateTime);
    qrlTitle.Caption := 'TANDA TERIMA';

    with qu001,SQL do
    Begin
      Close;Clear;
      add('Select A.RIID,A.CustId,B.CustName,B.Address FROM ARTrReceiptHD A Inner Join ArMsCustomer B on A.CustID=B.CustID '
         +'Where A.RIID='''+quMainRIID.AsString+''' ');
      Open;
    End;

    With qu002,SQL do
    Begin
      Close;Clear;
      add('Select A.KoninvpelID as ItemName,A.FPS,A.noDo,A.noPO,A.Amount as Total FROm ArtrReceiptDt A Where A.RIID='''+quMainRIID.AsString+''' ');
      Open;
    End;

    MyReport.PreviewModal;

  finally
    free;
  end;
end;

procedure TfmARTrReceipt.bbFindClick(Sender: TObject);
begin
  inherited;
  with TfmSearch.Create(Self) do
    try
       Title := 'Transaksi Penerimaan Barang';
       SQLString := 'select B.CustName ,A.RIID as Nota,CONVERT(VARCHAR(10),A.TransDate,103) as Tgl from artrreceipthd A inner join ARMsCustomer B on A.CustId=B.CustId '
                   +'WHERE '+FSQLWhere
                   +' ORDER BY A.RIID';
       if ShowModal = MrOK then
       begin
         quMain.Locate('RIID',Res[1],[]);
       end;
    finally
       free;
    end;
end;

end.
