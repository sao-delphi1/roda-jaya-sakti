  if Bulan = '05' then dxBulan.Text := 'Mei' else
  if Bulan = '06' then dxBulan.Text := 'Juni' else
  if Bulan = '07' then dxBulan.Text := 'Juli' else
  if Bulan = '08' then dxBulan.Text := 'Agustus' else
  if Bulan = '09' then dxBulan.Text := 'September' else
  if Bulan = '10' then dxBulan.Text := 'Oktober' else
  if Bulan = '11' then dxBulan.Text := 'November' else
    dxBulan.Text := 'Desember';

  if StLap = 'Jual' then
  begin
    laTitle.Caption := 'Laporan Penjualan Per Pelanggan';
    rcNota.Caption := 'Detail per Pelanggan';
    with quAct, SQL do
      begin
      Close;Clear;
      Add('Select CustID, CustName From ARMsCustomer');
      Open;
      end;
  end else
  begin
    laTitle.Caption := 'Laporan PO Per Supplier';
    rcNota.Caption := 'Detail per Supplier';
    RgPeriode.Visible := False;
    rcRekapitulasi.Visible := False;
    rcNota.Top := 12;
    with quAct, SQL do
      begin
      Close;Clear;
      Add('Select SuppID as CustID,SuppName as CustName From APMsSupplier');
      Open;
      end;
  end;
end;

procedure TfmARRptPenjPerCustDlg.rbSelectClick(Sender: TObject);
begin
  inherited;
  if Sender=rbAll then
  begin
     dbgList.OptionsBehavior := dbgList.OptionsBehavior - [edgoMultiSelect];
