  inherited qu002: TADOQuery
    Parameters = <
      item
        Name = 'ItemId'
        DataType = ftString
        NumericScale = 255
        Precision = 255
        Size = 30
        Value = Null
      end>
    SQL.Strings = (
      
        'SELECT distinct C.SaleId,Convert(varchar(10),TransDate,103) as T' +
        'gl,'
      
        'Convert(varchar(8),TransDate,112), A.QTY,B.CustName,C.CurrId,A.P' +
        'rice,(A.Price*A.Qty) as Total '
      
        ' FROM ARTrPenjualanDt A INNER JOIN ARTrPenjualanHd C ON A.SaleId' +
        '=C.SaleId '
      'INNER JOIN ARMsCustomer B ON C.CustId=B.CustId'
      'WHERE ITEMID=:ItemId')
  end
end
