procedure TfmAPTrPurchaseOrder.dbgItemIDButtonClick(Sender: TObject;
  AbsoluteIndex: Integer);
var sQuery : string;
begin
  inherited;
  sQuery := 'SELECT DISTINCT K.ItemName as Nama_Barang,K.ItemID as Part_Number,K.Nota as Nomor_PR,K.TypeUnit,K.NoUnit, '
           +'ISNULL(SUM(K.Qty-K.Jumlah),0) as Qty,K.UOMID,K.NumAll as IDTXN FROM ( '
           +'SELECT B.Transdate,C.ItemName,A.TypeUnit,A.NoUnit,A.PRID as Nota,A.Jumlah as Qty,A.UOMID,A.NumAll,ISNULL(A.FgOto,''W'') as FgOto, '
           +'ISNULL((SELECT SUM(X.Jumlah) as Total FROM APTrPurchaseOrderDt X INNER JOIN APTrPurchaseOrderHd Y ON X.POID=Y.POID '
           +'WHERE X.ItemID=A.ItemID AND X.PRID=A.PRID AND X.FgNum=A.NumAll AND X.FgOto=''Y''),0) as Jumlah,A.ItemID FROM APTrPurchaseRequestDt A '
           +'INNER JOIN APTrPurchaseRequestHd B ON A.PRID=B.PRID AND B.FgForm=''PR'' '
           +'AND B.SiteID='''+quMainSiteID.AsString+''' '
           +'INNER JOIN INMsItem C ON A.ItemID=C.ItemID '
           +'UNION ALL '
           +'select '''',A.itemName,A.typeUnit,''-'',''-'',1,A.uomid,1,''Y'',0,A.itemID FROM INMsItem A where Ctk<>''Y'' AND FgActive=''Y'' '
           +') as K WHERE ISNULL(K.Qty-K.Jumlah,0) > 0 AND K.FgOto IN (''Y'',''W'',''T'')  '
           +'AND CONVERT(VARCHAR(8),K.Transdate,112) <= '''+FormatDateTime('yyyyMMdd',quMainTransdate.AsDateTime)+''' '
           +'GROUP BY K.ItemName,K.TypeUnit,K.NoUnit,K.Nota,K.UOMID,K.ItemID,K.NumAll ORDER BY K.Nota,K.ItemName';
           //ShowMessage(sQuery);
  with TfmSearch.Create(Self) do
  try
    Title := 'Data Permintaan Barang';
    SQLString := sQuery;
    if ShowModal = MrOK then
    begin
       if quDetil.State = dsBrowse then quDetil.Edit;
       quDetilItemID.AsString := Res[1];
       quDetilJumlah.AsCurrency   := StrToCurr(Res[5]);
       quDetilPRID.AsString := Res[2];
       quDetilUOMID.AsString  := Res[6];
       quDetilFgNum.AsInteger := StrtoInt(Res[7]);
       quDetilTypeUnit.AsString := Res[3];
       quDetilNoUnit.AsString := Res[4];
    end;
  finally
    free;
  end;
end;

