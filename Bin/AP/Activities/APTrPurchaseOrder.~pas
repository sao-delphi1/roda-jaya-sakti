  with quAct, SQL do
  begin
    Close; Clear;
    Add('SELECT TOP 1 A.POID,A.KonsinyasiInvId FROM APTrKonsinyasiInvDt A inner join Aptrkonsinyasiinvhd B on A.Konsinyasiinvid=b.Konsinyasiinvid '
       +'WHERE A.POID='''+quMainPOID.AsString+''' AND B.FgOto IN (''Y'',''T'') ');
