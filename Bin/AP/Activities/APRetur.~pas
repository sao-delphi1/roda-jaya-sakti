procedure TfmAPRetur.quDetilCalcFields(DataSet: TDataSet);
var Disc : Currency;
begin
  inherited;
  with quAct,sql do
  Begin
    Close;Clear;
    Add(' Select TransDate,CurrID,Rate,FgTax,Disc FROM APTrPurchaseHd WHERE PurchaseId='''+quDetilPurchaseID.AsString+''''
       +' AND SuppId='''+quMainSuppID.AsString+''' UNION ALL '
       +'SELECT Transdate,CurrID,Rate,FgTax,Disc FROM APTrKonsinyasiInvHd WHERE KonsinyasiInvID='''+quDetilPurchaseID.AsString+''' '
       +' AND SuppID='''+quMainSuppID.AsString+''' ');
    Open;
  End;
  quDetilLFgtax.AsString:=quAct.FieldByName('FgTax').AsString;
  quDetilCValuta.Value:=quAct.FieldByName('CurrId').AsString;
  quDetilCRate.AsCurrency :=quAct.FieldByName('Rate').AsCurrency;
  Disc := quAct.FieldByName('Disc').AsCurrency;

  if quAct.FieldByName('FgTax').AsString ='Y' then
  quDetilATotal.AsCurrency := ((quDetilQty.AsCurrency*quDetilPrice.AsCurrency)-((quDetilQty.AsCurrency*quDetilPrice.AsCurrency)*Disc*0.01))*1.1
  else
  quDetilATotal.AsCurrency := (quDetilQty.AsCurrency*quDetilPrice.AsCurrency)-((quDetilQty.AsCurrency*quDetilPrice.AsCurrency)*Disc*0.01);
end;

