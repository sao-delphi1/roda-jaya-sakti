procedure TfmAPRetur.CekPegRet;
Begin //cek apakah sudah ada Peg Retur kalo sudah ada tidak bisa di utak atik
   with quAct, SQL do
   begin
      Close; Clear;
      Add('SELECT top 1 ReturnRepID FROM APTrReturnRepDt WHERE ReturnID='''+quMainReturnID.Value+'''');
      Open;
      if not IsEmpty then
      begin
         MsgInfo('Sudah ada Pengganti Retur ['+quAct.fieldbyname('ReturnRepId').AsString+'], tidak bisa edit/Delete lagi');
         Abort;
      end;
   end;
End;

procedure TfmAPRetur.CekTotal;
var Total,PPN,Disc : currency;
Begin
   with quAct, SQL do
   begin
      Close; Clear;
      Add('SELECT ISNULL(SUM(CASE WHEN K.FgTax=''Y'' THEN ((K.Price*K.Qty)-((K.Price*K.Qty)*K.Disc*0.01))*1.1 ELSE (K.Price*K.Qty)-((K.Price*K.Qty)*K.Disc*0.01) END),0) as TTLRetur, '
         +'       ISNULL(SUM(CASE WHEN K.FgTax=''Y'' THEN ((K.Price*K.Qty)-((K.Price*K.Qty)*K.Disc*0.01))*0.1 ELSE 0 END),0) as TTLPPN, '
         +'ISNULL(SUM((K.Price*K.Qty)*K.Disc*0.01),0) as Disc FROM ( '
         +'SELECT A.ReturnID,A.PurchaseID,A.Price,A.Qty,(SELECT B.FgTax FROM ApTrKonsinyasiInvHD B Where B.KonsinyasiInvId=A.PurchaseId) as FgTax, '
         +'(SELECT B.Disc FROM ApTrKonsinyasiInvHD B Where B.KonsinyasiInvId=A.PurchaseId) as Disc '
         +'FROM APTrReturnDT A WHERE A.ReturnID='''+quMainReturnID.AsString+''' ) as K ');
      Open;
   end;
   Total := quAct.FieldByName('TTLRetur').AsCurrency;
   PPN := quAct.FieldByName('TTLPPN').AsCurrency;
   Disc := quAct.FieldByName('Disc').AsCurrency;
   with quAct, SQL do
   begin
      Close; Clear;
      Add('UPDATE APTrReturnHD SET TTLRetur='''+CurrToStr(Total)+''',TTLPPN='''+CurrToStr(PPN)+''',TTLDiskon='''+CurrToStr(Disc)+''' WHERE ReturnID='''+quMainReturnID.AsString+''' ');
      ExecSQL;
   end;
   quTotal.Requery();
End;

