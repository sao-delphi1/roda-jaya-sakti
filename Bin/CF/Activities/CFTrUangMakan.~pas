procedure TfmCFTrUangMakan.bbSimpanClick(Sender: TObject);
begin
  inherited;
  if Self.quDetil.State = dsInsert then
  begin
   Self.quDetil.Edit;
   Self.quDetil.Post;
   Self.quDetil.Requery();
  end;
  if Self.quDetil.State = dsEdit then
  begin
   quDetil.Post;
  end;
end;

procedure TfmCFTrUangMakan.quDetilBeforePost(DataSet: TDataSet);
begin
  inherited;
  with quAct1,sql do
  Begin
    Close; Clear;
    Add('Select Tanggal FROM CfTrUangMakanDT Where UMID='''+quMainUMID.AsString+''' AND Salesid='''+quMainsalesid.AsString+''' AND CONVERT(Varchar(8),Tanggal,112)='''+FormatDateTime('yyyyMMdd',quDetiltanggal.AsDateTime)+''' ');
    Open;
  End;
  if quAct1.RecordCount <> 0 then
  begin
    ShowMessage('Tanggal Transaksi Sudah Ada');
    quDetilTanggal.FocusControl;
    Abort;
  end;
end;

