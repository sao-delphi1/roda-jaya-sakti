                     +'WHERE K.SuppID='''+quMainActor.AsString+''' AND '
                     +'CONVERT(VARCHAR(10),K.Transdate,112) <='''+FormatDateTime('yyyyMMdd',quMainTransDate.AsDateTime)+''' '
                     +'AND ISNULL(K.TTLPb-K.Bayar,0) <> 0' ;
