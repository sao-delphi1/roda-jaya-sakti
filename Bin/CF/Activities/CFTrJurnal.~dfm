  inherited quMain: TADOQuery
    CursorType = ctStatic
    SQL.Strings = (
      
        'SELECT K.VoucherID,CONVERT(VARCHAR(10),K.Transdate,103) as Tgl,K' +
        '.Actor,L.BankName,K.Note,K.FlagKKBB,K.CurrID,K.JumlahD,K.JumlahK' +
        ','
      'CASE WHEN K.FlagKKBB='#39'PCM'#39' THEN '#39'KAS MASUK'#39
      '     WHEN K.FlagKKBB='#39'PCK'#39' THEN '#39'KAS KELUAR'#39
      '     WHEN K.FlagKKBB='#39'BNM'#39' THEN '#39'BANK MASUK'#39
      '     WHEN K.FlagKKBB='#39'BNK'#39' THEN '#39'BANK KELUAR'#39
      '     WHEN K.FlagKKBB='#39'GC'#39' THEN '#39'PENCAIRAN CHEQUE / GIRO'#39
      '     WHEN K.FlagKKBB='#39'GL'#39' THEN '#39'JURNAL MEMORIAL'#39
      
        '     WHEN K.FlagKKBB='#39'INV'#39' THEN '#39'INVOICE PENJUALAN'#39' END as Statu' +
        's'
      ' FROM ('
      
        'SELECT CASE WHEN FlagKKBB='#39'GC'#39' THEN IDVoucher ELSE VoucherID END' +
        ' as VoucherID,'
      
        'Transdate,Actor,A.BankID,A.Note,FlagKKBB,CurrID,JumlahD,JumlahK ' +
        'FROM CFTrKKBBHd A'
      'WHERE FgPayment='#39'T'#39' UNION ALL'
      
        'SELECT KonInvPelID,Transdate,CustName,A.BankID,A.Note,'#39'INV'#39',Curr' +
        'ID,A.TTLKj,A.TTLKj FROM ARTrKonInvPelHd A'
      'INNER JOIN ARMsCustomer B ON A.CustID=B.CustID) as K'
      'LEFT JOIN CFMsBank L ON K.BankID=L.BankID'
      'WHERE K.FlagKKBB='#39'KM'#39)
