    Parameters = <>
    SQL.Strings = (
      
        'SELECT K.VoucherID,K.RekeningID,L.RekeningName,K.Note,K.Amount a' +
        's Debit,K.Amount as Kredit FROM ('
      
        'SELECT VoucherID,RekeningID,Amount,Note,CASE WHEN Jenis='#39'D'#39' THEN' +
        ' 2 ELSE 3 END as Urut,Jenis FROM CFTrKKBBDt UNION ALL'
      
        'SELECT VoucherID,'#39'1.11001.0001'#39' as RekeningID,ISNULL(JumlahD,0) ' +
        'as Amount,Note,1 as Urut,'#39'D'#39' as Jenis FROM CFTrKKBBHd) as K '
