unit InputNo;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, DB, ADODB;

type
  TfmInputNo = class(TForm)
    Edit1: TEdit;
    Button1: TButton;
    Button2: TButton;
    Label1: TLabel;
    quAct: TADOQuery;
    Label2: TLabel;
    procedure FormShow(Sender: TObject);
    procedure Button2Click(Sender: TObject);
    procedure Button1Click(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  fmInputNo: TfmInputNo;

implementation

{$R *.dfm}
uses UnitGeneral, MyUnit, ConMain;

procedure TfmInputNo.FormShow(Sender: TObject);
begin
  Edit1.SetFocus;
end;

procedure TfmInputNo.Button2Click(Sender: TObject);
begin
  Close;
end;

procedure TfmInputNo.Button1Click(Sender: TObject);
begin
  with quAct,SQL do
  begin
    Close;Clear;
    Add('UPDATE APTrKonsinyasiInvSub Set FPS='''+Edit1.Text+''' WHERE KonsinyasiInvID='''+Label1.Caption+''' AND POID='''+Label2.Caption+''' ');
    Add('UPDATE APTrPurchaseID Set POID='''+Edit1.Text+''' WHERE PurchaseID='''+Label1.Caption+''' ');
    ExecSQL;
  end;
  ShowMessage('Sudah Berhasil Di-Update');
  ModalResult := MrOK;
end;

end.
