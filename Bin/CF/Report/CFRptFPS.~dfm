      'select * from ('
      
        'select A.Transdate,A.KonsinyasiInvID,C.POID,B.SuppName,C.Subtota' +
        'lM+C.SubtotalU as  SubTotal,C.DiscAmount as Disc,C.PPN,C.TTLKJ a' +
        's TTLKS,A.FPS,A.transdate as tglFPS from APTrKonsinyasiInvSub C'
      
        'inner join APTrKonsinyasiInvHd A on A.KonsinyasiInvID=C.Konsinya' +
        'siInvID'
      ''
      'inner join APMsSupplier B on A.SuppID=B.SuppID'
      'WHere A.PPN<>0'
      'UNION ALL'
      
        'select A.TransDate,A.PurchaseID,'#39#39',B.SuppName,A.StPb,A.DiscAmoun' +
        't,A.PPN,A.TTLPb,A.POID,A.tglFPS from APTrPurchaseHd A inner join' +
        ' APMsSupplier B on A.SuppID=B.SuppID'
      'where A.PPN<>0 AND A.FgPajak='#39'Y'#39
