end;

procedure TfmCFRptFPS.dxDBGrid1DblClick(Sender: TObject);
begin
  inherited;
  with TfmInputNo.Create (Application) do
  try
    tgldari := quMainTransdate.ASdatetime;
    Label1.Caption:=quMainKonsinyasiInvID.AsString;
    Label2.Caption:=quMainPOID.AsString;
    ShowModal;
  finally
    Free;
  end;
  Button1Click(Button1);
end;

