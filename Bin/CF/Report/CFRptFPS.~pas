     Title := 'CARI NOMOR FPP';
     SQLString := ' select K.KonsinyasiInvID as FPP,K.POID as Nomor_PO,CONVERT(VARCHAR(10),K.Transdate,103) as Tanggal,K.SuppName as Supplier,ISNULL(K.FPS,''Belum Ada Nomor Faktur'') as Faktur from ( '
                 +' select A.KonsinyasiInvID,A.Transdate,B.SuppName,C.FPS,C.POID,C.tglFPS from APTrKonsinyasiInvSub C '
                 +' inner join aptrkonsinyasiinvhd A on A.KonsinyasiInvId=C.KonsinyasiInvId '
                 +' inner join APMsSupplier B on A.SuppID=B.SuppID '
                 +' WHere A.PPN<>0 AND A.FgOto<>''X'' '
                 +' UNION ALL '
                 +' select A.PurchaseID,A.Transdate,B.SuppName,A.POID,'''',A.tglFPS from APTrPurchaseHd A '
                 +' inner join APMsSupplier B on A.SuppID=B.SuppID '
                 +' where A.PPN<>0 AND A.FgPajak=''Y'' AND A.FGOto<>''X'' '
                 +' ) as K ';
     if RadioGroup1.ItemIndex=0 then
     SQLString := SQLString + ' WHERE ISNULL(K.FPS,'''')='''' or ISNULL(K.tglFPS,'''')='''' ';
     if RadioGroup1.ItemIndex=1 then
     SQLString := SQLString + ' WHERE ISNULL(K.FPS,'''')<>'''' AND ISNULL(K.tglFPS,'''')<>'''' ';
     if RadioGroup2.ItemIndex=0 then
     SQLString := SQLString + ' ORDER BY K.TransDate '
     else
