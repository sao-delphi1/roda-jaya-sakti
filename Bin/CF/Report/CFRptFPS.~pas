uses Search, MyUnit, UnitGeneral, InputNo;
{$R *.dfm}

procedure TfmCFRptFPS.FormCreate(Sender: TObject);
begin
  inherited;
  UsePeriod := False;
end;

procedure TfmCFRptFPS.FormShow(Sender: TObject);
begin
  inherited;
  quMain.Active := TRUE;
  RadioGroup1.Top := 8;
  RadioGroup2.Top := 104;
  Button1Click(Button1);
end;

procedure TfmCFRptFPS.Button1Click(Sender: TObject);
begin
  inherited;
  with quMain,SQL do
  begin
    Close;Clear;
    Add(' select * from ( '
       +' select A.Transdate,A.KonsinyasiInvID,C.POID,B.SuppName,C.SubTotalM+C.SubTotalU as Subtotal,C.DiscAmount as Disc,C.PPN,C.TTLKJ as TTLKS, '
       +' ISNULL(C.FPS,'''') as FPS,C.tglFPS from APTrKonsinyasiInvSub C '
       +' inner join APTrKonsinyasiInvHd A on A.KonsinyasiInvID=C.KonsinyasiInvID '
       +' inner join APMsSupplier B on A.SuppID=B.SuppID '
       +' WHere A.PPN<>0 AND A.FgOto<>''X'' '
       +' UNION ALL '
       +' select A.TransDate,A.PurchaseID,'''',B.SuppName,A.StPb,A.DiscAmount,A.PPN,A.TTLPb,ISNULL(A.POID,''''),A.tglFPS from APTrPurchaseHd A '
       +' inner join APMsSupplier B on A.SuppID=B.SuppID '
       +' where A.PPN<>0 AND A.FgPajak=''Y'' AND A.FgOto<>''X'' '
       +' ) as K ');
    if RadioGroup1.ItemIndex=0 then
    Add(' WHERE ISNULL(K.FPS,'''')='''' or ISNULL(K.tglFPS,'''')='''' ');
    if RadioGroup1.ItemIndex=1 then
    Add(' WHERE ISNULL(K.FPS,'''')<>'''' AND ISNULL(K.tglFPS,'''')<>'''' ');
    if RadioGroup2.ItemIndex=0 then
    Add(' ORDER BY K.TransDate ')
    else
    Add(' ORDER BY K.TransDate DESC ');
    Open;
  end;
end;

